{
  "name": "algox-complexity-analyzer",
  "displayName": "algox-complexity-analyzer",
  "description": "Explainable AI Model for Code Runtime Complexity Classification",
  "version": "0.0.1",
  "publisher": "thamindu-nethmina",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThaminduNethmina/fyp-extension.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:java"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "algox-complexity-analyzer.analyze",
        "title": "AlgoX: Analyze Time Complexity"
      },
      {
        "command": "algox-complexity-analyzer.clear",
        "title": "AlgoX: Clear Highlights"
      }
    ],

    "keybindings": [
      {
        "command": "algox-complexity-analyzer.analyze",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus && (editorLangId == python || editorLangId == java)"
      },
      {
        "command": "algox-complexity-analyzer.clear",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
